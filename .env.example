# Server
DOMAIN=yourdomain.com
HETZNER_IP=x.x.x.x

# MongoDB (your dedicated cluster)
MONGODB_URI=mongodb+srv://...
MONGODB_DB=offerberries_agent

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Redis
REDIS_URL=redis://redis:6379

# Owner (you) — Tenant #1
OWNER_API_KEY=                         # generate: openssl rand -hex 32
OWNER_TENANT_ID=00000000-0000-0000-0000-000000000001

# LLM APIs
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=                     # for premium content generation

# Scraping
APIFY_API_TOKEN=

# Image generation
FAL_API_KEY=

# Open Design daemon
OD_API_TOKEN=                          # generate: openssl rand -hex 32
OD_BIND_HOST=0.0.0.0
OPEN_DESIGN_PORT=7456
OPEN_DESIGN_ALLOWED_ORIGINS=https://agent.${DOMAIN},https://design.${DOMAIN}

# Publishing
POSTIZ_SECRET=                         # generate: openssl rand -hex 32

# Payments
SAFEPAY_API_KEY=
SAFEPAY_WEBHOOK_SECRET=
TWOCHECKOUT_SELLER_ID=
TWOCHECKOUT_SECRET_KEY=

# Postgres (shared for Postiz + n8n)
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=                     # generate: openssl rand -hex 24
POSTGRES_DB=agent_db

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_ENCRYPTION_KEY=                    # generate: openssl rand -hex 32

# Dashboard
NEXTAUTH_SECRET=                       # generate: openssl rand -hex 32
NEXTAUTH_URL=https://agent.${DOMAIN}
MCP_SERVER_URL=http://mcp-server:8000

# MongoDB Atlas Admin (for tenant provisioning)
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
ATLAS_GROUP_ID=

# Monitoring
GRAFANA_ADMIN_PASSWORD=                # generate: openssl rand -hex 16

# n8n Webhook token
N8N_WEBHOOK_TOKEN=                     # generate: openssl rand -hex 32

# Resend (transactional email)
RESEND_API_KEY=
